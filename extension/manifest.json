{
  "manifest_version": 3,
  "name": "Voided Video Downloader",
  "version": "0.3.0",
  "description": "Adds a download control to the YouTube player and sends downloads to a local yt-dlp backend.",
  "key": "",
  "permissions": [
    "cookies",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://*.google.com/*",
    "https://*.youtube.com/*",
    "https://accounts.google.com/*",
    "https://m.youtube.com/*",
    "https://www.youtube.com/*",
    "https://youtu.be/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
